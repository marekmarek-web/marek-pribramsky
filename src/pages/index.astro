---
import BaseLayout from '../layouts/BaseLayout.astro';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Audience from '../components/Audience.astro';
import Services from '../components/Services.astro';
import ProcessStack from '../components/ProcessStack.astro';
import Testimonials from '../components/Testimonials.astro';
import BlogTeaser from '../components/BlogTeaser.astro';
import LeadCTA from '../components/LeadCTA.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Premium Brokers – Privátní finanční plánování">
  <Topbar />
  <Header />
  <main>
    <Hero />
    <Audience />
    <Services />
    <ProcessStack />
    <Testimonials />
    <BlogTeaser />
    <LeadCTA />
  </main>
  <Footer />

  <script>
    import { initFadeInObserver } from '../scripts/fadeInObserver';
    initFadeInObserver();
  </script>
</BaseLayout>
