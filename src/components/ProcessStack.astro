---
const steps = [
  { num: '01', title: 'Úvodní konzultace', desc: 'Seznámíme se, probereme vaši situaci a očekávání. Nezávazně, v klidu.' },
  { num: '02', title: 'Analýza', desc: 'Projdeme finance, cíle a rizika. Získáte přehled o tom, kde jste a kam směřujete.' },
  { num: '03', title: 'Plán', desc: 'Připravíme konkrétní doporučení – investiční strategie, pojištění, hypotéka či komplexní plán.' },
  { num: '04', title: 'Servis', desc: 'Pravidelný dohled, úpravy a podpora. Jsme tu pro vás dlouhodobě.' },
];

const prepareItems = ['Přehled příjmů a výdajů', 'Seznam stávajících smluv a investic', 'Vaše finanční cíle a časový horizont'];
---
<section id="spoluprace" class="py-20 lg:py-28 bg-white" aria-labelledby="process-title">
  <div class="max-w-content mx-auto px-4 sm:px-6">
    <div class="text-center mb-16 animate-fade-in-up">
      <h2 id="process-title" class="text-3xl lg:text-4xl font-bold text-brand-text mb-4">Jak probíhá spolupráce</h2>
      <p class="text-brand-muted max-w-2xl mx-auto text-lg">
        Transparentní proces v několika krocích. Žádné překvapení, jasná komunikace.
      </p>
    </div>

    <div class="lg:grid lg:grid-cols-5 lg:gap-12">
      <div class="lg:col-span-3 space-y-6 lg:space-y-0">
        <div class="lg:relative lg:min-h-[1400px]">
          {steps.map((step, i) => (
            <div
              class="animate-fade-in-up lg:sticky lg:pt-6"
              style={`top: ${1.5 + i}rem`}
            >
              <div class="bg-brand-background rounded-2xl border border-brand-border p-8 shadow-sm lg:shadow-md hover:shadow-md transition-shadow">
                <span class="text-3xl font-bold text-brand-cyan/60 mb-4 block">{step.num}</span>
                <h3 class="text-xl font-bold text-brand-text mb-3">{step.title}</h3>
                <p class="text-brand-muted leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="lg:col-span-2 mt-12 lg:mt-0">
        <div class="animate-fade-in-up bg-brand-navy rounded-2xl p-8 text-white lg:sticky lg:top-32">
          <h3 class="text-lg font-bold mb-6">Co si připravit</h3>
          <ul class="space-y-4">
            {prepareItems.map((item) => (
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 rounded-full bg-brand-cyan/20 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-brand-cyan" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                </span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>
