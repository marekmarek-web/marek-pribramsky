---
const navItems = [
  { href: '#sluzby', label: 'Služby' },
  { href: '/blog', label: 'Blog' },
  { href: '#spoluprace', label: 'Spolupráce' },
  { href: '#lead-form', label: 'Kontakt' },
];
---
<header class="bg-white border-b border-brand-border sticky top-0 z-40" role="banner" aria-label="Hlavní navigace">
  <div class="max-w-content mx-auto px-4 sm:px-6">
    <div class="flex justify-between items-center h-16 lg:h-20">
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Premium Brokers – Domů">
        <div class="w-10 h-10 rounded-xl bg-brand-navy flex items-center justify-center">
          <span class="text-white font-bold text-lg">PB</span>
        </div>
        <span class="font-bold text-brand-text text-lg">Premium Brokers</span>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Hlavní menu">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-4 py-2 rounded-lg text-brand-text font-medium hover:bg-brand-background hover:text-brand-navy transition-colors"
          >
            {item.label}
          </a>
        ))}
        <a
          href="#lead-form"
          class="ml-4 px-5 py-2.5 rounded-xl bg-brand-navy text-white font-semibold hover:bg-brand-navy/90 transition-colors focus:outline-none focus:ring-2 focus:ring-brand-cyan focus:ring-offset-2"
        >
          Domluvit konzultaci
        </a>
      </nav>

      <button
        type="button"
        class="lg:hidden p-2 rounded-lg text-brand-text hover:bg-brand-background aria-label="Otevřít menu"
        id="mobile-menu-btn"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="hidden lg:hidden absolute top-full left-0 right-0 bg-white border-b border-brand-border shadow-lg"
    role="navigation"
    aria-label="Mobilní menu"
  >
    <div class="px-4 py-4 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-4 py-3 rounded-xl font-medium text-brand-text hover:bg-brand-background"
        >
          {item.label}
        </a>
      ))}
      <a
        href="#lead-form"
        class="block mx-4 mt-4 py-3 rounded-xl bg-brand-navy text-white text-center font-semibold"
      >
        Domluvit konzultaci
      </a>
    </div>
  </div>
</header>

<script>
  const closeMobileMenu = () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('mobile-menu-btn');
    if (menu && btn) {
      menu.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    }
  };
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    const btn = document.getElementById('mobile-menu-btn');
    if (menu && btn) {
      menu.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', menu.classList.contains('hidden') ? 'false' : 'true');
    }
  });
  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });
</script>
