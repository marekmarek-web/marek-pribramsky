---
const navLinks = [
  { href: '#sluzby', label: 'Služby' },
  { href: '/blog', label: 'Blog' },
  { href: '#spoluprace', label: 'Spolupráce' },
  { href: '#lead-form', label: 'Kontakt' },
];
---
<footer class="bg-brand-navy text-white py-16" role="contentinfo">
  <div class="max-w-content mx-auto px-4 sm:px-6">
    <div class="grid md:grid-cols-4 gap-12 mb-12">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 rounded-xl bg-white/10 flex items-center justify-center">
            <span class="font-bold text-lg">PB</span>
          </div>
          <span class="font-bold text-xl">Premium Brokers</span>
        </div>
        <p class="text-slate-300 text-sm max-w-sm">
          Privátní finanční plánování pro lidi, kteří chtějí mít klid. Pomáháme rodinám a podnikatelům sestavit strategie, které dávají smysl.
        </p>
      </div>

      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">Rychlé odkazy</h4>
        <ul class="space-y-2 text-sm">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-slate-300 hover:text-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-bold text-sm uppercase tracking-wider mb-4">Kontakt</h4>
        <ul class="space-y-3 text-sm text-slate-300">
          <li>
            <a href="tel:+420778511166" class="hover:text-white transition-colors">+420 778 511 166</a>
          </li>
          <li>
            <a href="mailto:info@premiumbrokers.cz" class="hover:text-white transition-colors">info@premiumbrokers.cz</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-slate-400">
      <p>&copy; {new Date().getFullYear()} Premium Brokers. Všechna práva vyhrazena.</p>
      <div class="flex gap-6">
        <a href="/gdpr" class="hover:text-white transition-colors">Ochrana osobních údajů</a>
        <a href="/cookies" class="hover:text-white transition-colors">Cookies</a>
      </div>
    </div>
  </div>
</footer>
