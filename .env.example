# --- Resend (odesílání leadů z /api/leads) ---
# API klíč z Resend dashboardu (Production: jen v Vercel / lokálně v .env.local).
RESEND_API_KEY=

# Kam chodí notifikace o novém leadu (výchozí v kódu: pribramsky@premiumbrokers.cz).
LEAD_EMAIL_TO=pribramsky@premiumbrokers.cz

# Odesílatel: musí být z ověřené domény v Resend (ne onboarding@resend.dev v produkci).
# Příklad: Premium Brokers <lead@premiumbrokers.cz>
RESEND_FROM=

# --- Veřejná URL webu (canonical, odkazy v e-mailu na /admin/leads/...) ---
NEXT_PUBLIC_SITE_URL=https://www.vasedomena.cz

# --- Supabase (volitelné — ukládání leadů do DB; e-mail jde i bez toho pokud Resend běží) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
