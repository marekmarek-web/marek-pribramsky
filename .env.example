# --- Resend (notifikace: /api/leads, /api/subscribers, kariéra přes server action) ---
# API klíč z Resend dashboardu (Production: jen v Vercel / lokálně v .env.local).
RESEND_API_KEY=

# Kam chodí notifikace o leadu / novém odběru novinek (výchozí: pribramsky@premiumbrokers.cz).
LEAD_EMAIL_TO=pribramsky@premiumbrokers.cz

# Odesílatel: v produkci musí být z ověřené domény v Resend (Domains).
# Bez ověřené domény selžou i /api/leads, /api/subscribers i kariérní wizard (stejný API klíč).
# Příklad: Premium Brokers <lead@premiumbrokers.cz>
RESEND_FROM=

# --- Veřejná URL webu (canonical, odkazy v e-mailu na /admin/leads/...) ---
NEXT_PUBLIC_SITE_URL=https://www.vasedomena.cz

# Volitelné: při lokálním běhu `pnpm gh-pages:redirects` přebije URL v config/gh-pages-redirect-base.txt
# GH_PAGES_REDIRECT_BASE=https://vase-projekty.vercel.app

# --- Supabase (volitelné — ukládání leadů do DB; e-mail jde i bez toho pokud Resend běží) ---
# NEXT_PUBLIC_SUPABASE_URL=
# Dva RŮZNÉ klíče z Dashboard → API → Legacy: anon (public) = jen ANON_KEY; service_role (secret) = jen SERVICE_ROLE_KEY. Nikdy stejný řetězec do obou.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nebo nový publishable místo anon (stačí jedno z nich):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Cookie lišta: na localhostu a v NODE_ENV=development se ve výchozím stavu nezobrazí (rychlejší náhled).
# Pokud ji při lokálním vývoji potřebujete testovat, nastavte:
# NEXT_PUBLIC_SHOW_COOKIE_BANNER_IN_DEV=1
